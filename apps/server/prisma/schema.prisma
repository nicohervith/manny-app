generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int            @id @default(autoincrement())
  name             String
  email            String         @unique
  password         String
  role             Role           @default(CLIENT)
  createdAt        DateTime       @default(now())
  
  profile          WorkerProfile?
  jobsAsClient     Job[]          @relation("ClientJobs")
  jobsAsWorker     Job[]          @relation("WorkerJobs")
  bids             Bid[]          @relation("WorkerBids")
  sentMessages     Message[]      @relation("SentMessages")
  
  // CAMPOS AÑADIDOS PARA LAS REVIEWS:
  sentReviews      Review[]       @relation("SentReviews")
  receivedReviews  Review[]       @relation("ReceivedReviews")
  
  pushToken        String?
}

model Job {
  id          Int             @id @default(autoincrement())
  title       String
  description String          @db.Text
  status      JobStatus       @default(PENDING)
  budget      Float?
  latitude    Float?
  longitude   Float?
  address     String?
  createdAt   DateTime        @default(now())
  updatedAt DateTime @updatedAt
  clientId    Int
  client      User            @relation("ClientJobs", fields: [clientId], references: [id])

  workerId    Int?
  worker      User?           @relation("WorkerJobs", fields: [workerId], references: [id])

  adjustments JobAdjustment[]
  bids        Bid[]
  messages    Message[]
  
  // CAMPO AÑADIDO PARA LA REVIEW:
  review      Review?         // Un trabajo puede tener una reseña
}

model Review {
  id         Int      @id @default(autoincrement())
  rating     Int      // 1 a 5
  comment    String   @db.Text
  createdAt  DateTime @default(now())

  jobId      Int      @unique
  job        Job      @relation(fields: [jobId], references: [id])
  
  reviewerId Int
  reviewer   User     @relation("SentReviews", fields: [reviewerId], references: [id])
  
  workerId   Int
  worker     User     @relation("ReceivedReviews", fields: [workerId], references: [id])
}

model WorkerProfile {
  id          Int      @id @default(autoincrement())
  occupation  String   // Ej: Plumber
  description String   @db.Text
  dni         String   @unique
  dniPhoto    String?  
  hourlyRate  Float?
  lastLat     Float?
  lastLng     Float?

  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  latitude    Float?
  longitude   Float?
}

model Bid {
  id          Int      @id @default(autoincrement())
  message     String   @db.Text
  price       Float
  estimatedMin Int     
  createdAt   DateTime @default(now())

  status       BidStatus @default(PENDING)

  jobId       Int
  job         Job      @relation(fields: [jobId], references: [id])

  workerId    Int
  worker      User     @relation("WorkerBids", fields: [workerId], references: [id])
}

model JobAdjustment {
  id          Int      @id @default(autoincrement())
  reason      String
  prevAmount  Float
  newAmount   Float
  jobId       Int
  job         Job      @relation(fields: [jobId], references: [id])
}

enum Role {
  CLIENT
  WORKER
  ADMIN
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  createdAt DateTime @default(now())
  read      Boolean  @default(false) // <--- Nuevo campo
  senderId  Int
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
  jobId     Int
  job       Job      @relation(fields: [jobId], references: [id])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int            @id @default(autoincrement())
  name             String
  email            String         @unique
  password         String
  role             Role           @default(CLIENT)
  createdAt        DateTime       @default(now())
  
  profile          WorkerProfile?
  jobsAsClient     Job[]          @relation("ClientJobs")
  jobsAsWorker     Job[]          @relation("WorkerJobs")
  bids             Bid[]          @relation("WorkerBids")
}

model WorkerProfile {
  id          Int      @id @default(autoincrement())
  occupation  String   // Ej: Plumber
  description String   @db.Text
  dni         String   @unique
  dniPhoto    String?  
  hourlyRate  Float?
  lastLat     Float?
  lastLng     Float?

  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id          Int           @id @default(autoincrement())
  title       String
  description String        @db.Text
  status      JobStatus     @default(PENDING)
  budget      Float?
  latitude    Float?
  longitude   Float?
  address     String?
  createdAt   DateTime      @default(now())

  clientId    Int
  client      User          @relation("ClientJobs", fields: [clientId], references: [id])

  workerId    Int?
  worker      User?         @relation("WorkerJobs", fields: [workerId], references: [id])

  adjustments JobAdjustment[]
  bids        Bid[]
}

model Bid {
  id          Int      @id @default(autoincrement())
  message     String   @db.Text
  price       Float
  estimatedMin Int     
  createdAt   DateTime @default(now())

  jobId       Int
  job         Job      @relation(fields: [jobId], references: [id])

  workerId    Int
  worker      User     @relation("WorkerBids", fields: [workerId], references: [id])
}

model JobAdjustment {
  id          Int      @id @default(autoincrement())
  reason      String
  prevAmount  Float
  newAmount   Float
  jobId       Int
  job         Job      @relation(fields: [jobId], references: [id])
}

enum Role {
  CLIENT
  WORKER
  ADMIN
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}